# Kopieren nach .env

# --- Lokal ohne Docker (Standard unter Windows) ---
DATABASE_URL=file:../dev.db

# --- Optional: PostgreSQL (z. B. Docker: docker compose up -d) ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grabstein?schema=public"
# Dafür in prisma/schema.prisma wieder provider = "postgresql" setzen und
# generator um binaryTargets erweitern — siehe docs/VERCEL-POSTGRES.md

# --- SMTP (Phase 2: PDF per E-Mail) ---
# Ohne diese Variablen: PDF-Download funktioniert, Versand zeigt eine Fehlermeldung.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Grabstein <noreply@example.com>"
# Optional: zweite Mail mit Lieferanten-PDF (EN)
# SMTP_SUPPLIER_TO=einkauf@example.com
