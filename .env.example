# Nach .env kopieren. Lokal startet `docker compose up -d` PostgreSQL auf Port 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grabstein?schema=public"

# In Vercel eine gepoolte PostgreSQL-URL verwenden, z. B. von Neon.
# Zugangsdaten niemals in diese Datei oder in Git schreiben.

# SMTP (optional: PDF per E-Mail)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Grabstein <noreply@example.com>"
# SMTP_SUPPLIER_TO=einkauf@example.com

# Admin (fuer ein oeffentliches Deployment erforderlich)
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
