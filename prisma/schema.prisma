// Prisma schema — https://www.prisma.io/docs/reference/prisma-schema-reference
//
// Lokal: DATABASE_URL=file:../dev.db → Datei `dev.db` im Projektroot — siehe .env.example
// Produktion / Vercel: PostgreSQL — siehe docs/VERCEL-POSTGRES.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Auftrag oder Entwurf; Konfiguration als JSON (schemaVersion im JSON empfohlen).
model Order {
  id              String   @id @default(cuid())
  status          String   @default("draft")
  configuration   Json?
  customerEmail   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
